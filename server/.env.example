PORT=3001
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_CHAT_MODEL=qwen2.5:3b
OLLAMA_EMBED_MODEL=bge-m3
CHROMA_URL=http://127.0.0.1:8000
CHROMA_COLLECTION=nexus_kb
DATA_SOURCE_DIR=./data_source
MAX_FILE_BYTES=5242880
EMBED_BATCH_SIZE=16
# Candidatos bem ranqueados; o que vai para o LLM é no máximo o menor entre este valor e CHAT_PROMPT_MAX_CHUNKS.
CHAT_TOP_K=5
# Teto de trechos no prompt (e nas fontes). Modelos locais pequenos: 4–6. Suba se usar modelo maior e precisar de mais contexto.
CHAT_PROMPT_MAX_CHUNKS=6
# Turnos anteriores enviados ao LLM e usados na query de retrieval (0 = desliga histórico).
CHAT_HISTORY_MAX_MESSAGES=6
# Ingest (limita quantos batches de addDocuments rodam em paralelo)
INGEST_ADD_CONCURRENCY=2
CORS_ORIGINS=*
# Distância máxima por trecho (menor = mais parecido). Valores maiores aceitam trechos mais fracos → mais recall e mais ruído no prompt. Vazio = não filtra por trecho.
CHROMA_MAX_RETRIEVAL_DISTANCE=0.55
# Distância máxima do MELHOR trecho. Valores maiores evitam cair no modo "sem RAG" quando o embed da pergunta não casa bem com o doc; muito alto pode forçar contexto pouco relevante.
CHROMA_MAX_BEST_DISTANCE=0.48