PORT=3001
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_CHAT_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=nomic-embed-text
CHROMA_URL=http://127.0.0.1:8000
CHROMA_COLLECTION=nexus_kb
DATA_SOURCE_DIR=./data_source
MAX_FILE_BYTES=5242880
EMBED_BATCH_SIZE=16
CHAT_TOP_K=3
# Ingest (limita quantos batches de addDocuments rodam em paralelo)
INGEST_ADD_CONCURRENCY=2
CORS_ORIGINS=*
# Distância máxima por trecho (menor = mais parecido). Acima disso o trecho não entra no prompt nem vira fonte. Deixe vazio para não filtrar por trecho.
CHROMA_MAX_RETRIEVAL_DISTANCE=0.55
# Distância máxima do MELHOR trecho (1º resultado). Se o vizinho mais próximo for pior que isso, não há RAG nem fontes (útil para "oi", "qual seu nome").
CHROMA_MAX_BEST_DISTANCE=0.42